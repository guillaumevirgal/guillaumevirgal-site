---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const name = "Guillaume Virgal";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={post.data.description} />
    <title>{post.data.title} | {name}</title>
  </head>
  <body>
    <main>
      <a href="/blog" class="back">← Back to blog</a>
      <article>
        <header>
          <h1>{post.data.title}</h1>
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </header>
        <div class="content">
          <Content />
        </div>
      </article>
    </main>

    <style>
      :root {
        --text: #1a1a1a;
        --muted: #666;
        --accent: #1a1a1a;
        --bg: #fafaf7;
        --code-bg: #f0efe9;
        --border: #e5e3da;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 42rem;
        margin: 0 auto;
        padding: 4rem 1.5rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .back {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }

      .back:hover {
        color: var(--text);
      }

      article header {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }

      article h1 {
        font-size: 2.25rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      article time {
        font-size: 0.95rem;
        color: var(--muted);
      }

      .content {
        font-size: 1.0625rem;
      }

      .content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
      }

      .content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      .content p {
        margin-bottom: 1.25rem;
      }

      .content ul,
      .content ol {
        margin-bottom: 1.25rem;
        padding-left: 1.5rem;
      }

      .content li {
        margin-bottom: 0.5rem;
      }

      .content strong {
        font-weight: 600;
      }

      .content em {
        font-style: italic;
      }

      .content code {
        background: var(--code-bg);
        padding: 0.15em 0.4em;
        border-radius: 3px;
        font-size: 0.9em;
        font-family: "SF Mono", Menlo, Monaco, Consolas, monospace;
      }

      .content pre {
        background: var(--code-bg);
        padding: 1rem 1.25rem;
        border-radius: 6px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        line-height: 1.5;
      }

      .content pre code {
        background: transparent;
        padding: 0;
        font-size: inherit;
      }

      .content table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
      }

      .content th,
      .content td {
        text-align: left;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border);
      }

      .content th {
        font-weight: 600;
        background: var(--code-bg);
      }

      .content hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5rem 0;
      }

      .content img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 2rem auto;
        border-radius: 4px;
      }

      @media (max-width: 480px) {
        main {
          padding: 2.5rem 1.25rem;
        }
        article h1 {
          font-size: 1.75rem;
        }
        .content {
          font-size: 1rem;
        }
        .content h2 {
          font-size: 1.3rem;
        }
        .content pre {
          font-size: 0.85rem;
          padding: 0.875rem 1rem;
        }
      }
    </style>
  </body>
</html>