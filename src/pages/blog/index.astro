---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const name = "Guillaume Virgal";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Blog posts on robotics, embedded systems, and engineering by Guillaume Virgal" />
    <title>Blog | {name}</title>
  </head>
  <body>
    <main>
      <a href="/" class="back">← Back</a>
      <h1>Blog</h1>
      <ul class="posts">
        {posts.map(post => (
          <li>
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`}>
              <h2>{post.data.title}</h2>
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <p>{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <style>
      :root {
        --text: #1a1a1a;
        --muted: #666;
        --accent: #1a1a1a;
        --bg: #fafaf7;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 40rem;
        margin: 0 auto;
        padding: 6rem 1.5rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .back {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }

      .back:hover {
        color: var(--text);
      }

      h1 {
        font-size: 2rem;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      .posts {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      .posts a {
        color: var(--text);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: opacity 0.15s ease;
      }

      .posts a:hover {
        opacity: 0.7;
      }

      .posts h2 {
        font-size: 1.375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .posts time {
        font-size: 0.875rem;
        color: var(--muted);
      }

      .posts p {
        font-size: 1rem;
        color: var(--muted);
        line-height: 1.5;
      }

      @media (max-width: 480px) {
        main {
          padding: 3rem 1.25rem;
        }
        h1 {
          font-size: 1.75rem;
        }
        .posts h2 {
          font-size: 1.25rem;
        }
      }
    </style>
  </body>
</html>